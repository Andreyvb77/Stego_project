        return \"cat\"\n","    elif filename.startswith(\"dog\"):\n","        return \"dog\"\n","\n","    # Метод 2: из имени родительской папки\n","    parent_name = path.parent.name.lower()\n","    if \"cat\" in parent_name:\n","        return \"cat\"\n","    elif \"dog\" in parent_name:\n","        return \"dog\"\n","\n","    # Если не удалось определить\n","    return \"unknown\"\n","\n","# Сканирование датасета\n","print(f\"Сканирование: {dataset_root}\")\n","all_images = list_images_recursive(dataset_root)\n","\n","print(f\"Найдено изображений: {len(all_images)}\")\n","\n","# Создание датафрейма\n","data = []\n","for img_path in all_images:\n","    label = extract_label_from_path(img_path)\n","    data.append({\n","        \"path\": str(img_path),\n","        \"label\": label,\n","        \"filename\": img_path.name,\n","        \"ext\": img_path.suffix.lower(),\n","        \"stem\": img_path.stem,\n","    })\n","\n","df = pd.DataFrame(data)\n","\n","# Фильтрация неопределенных меток\n","df = df[df[\"label\"] != \"unknown\"].reset_index(drop=True)\n","\n","# Преобразование меток в числовые (для обучения)\n","label_map = {\"cat\": 0, \"dog\": 1}\n","df[\"label_num\"] = df[\"label\"].map(label_map)\n","\n","# Статистика\n","print(\"\\n=== Статистика датасета ===\")\n","print(f\"Всего изображений: {len(df)}\")\n","print(f\"\\nРаспределение классов:\")\n","print(df[\"label\"].value_counts())\n","print(f\"\\nБаланс классов:\")\n","print((df[\"label\"].value_counts() / len(df) * 100).round(2))\n","\n","# Просмотр первых строк\n","print(\"\\n=== Пример данных ===\")\n","print(df.head())\n","\n","# Сохранение датафрейма (опционально)\n","df.to_csv(dataset_root / \"dataset_index.csv\", index=False)\n","print(f\"\\nИндекс сохранен: {dataset_root / 'dataset_index.csv'}\")"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"N36HrAdg3NW_","executionInfo":{"status":"ok","timestamp":1774289151298,"user_tz":-300,"elapsed":58435,"user":{"displayName":"Genrih","u